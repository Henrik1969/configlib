@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/configlibTargets.cmake")

# Convenience target for consumers.
# Prefer the shared library when it was installed, otherwise use the static one.
if(NOT TARGET configlib::configlib)
    if(TARGET configlib::shared)
        add_library(configlib::configlib INTERFACE IMPORTED)
        set_target_properties(configlib::configlib PROPERTIES
            INTERFACE_LINK_LIBRARIES configlib::shared
        )
    elseif(TARGET configlib::static)
        add_library(configlib::configlib INTERFACE IMPORTED)
        set_target_properties(configlib::configlib PROPERTIES
            INTERFACE_LINK_LIBRARIES configlib::static
        )
    endif()
endif()

set(CONFIGLIB_VERSION "@PROJECT_VERSION@")
set(CONFIGLIB_HAS_SHARED @CONFIGLIB_BUILD_SHARED@)
set(CONFIGLIB_HAS_STATIC @CONFIGLIB_BUILD_STATIC@)

check_required_components(configlib)
