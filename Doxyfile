# SPDX-License-Identifier: MIT
# Doxygen configuration for configlib.
#
# HTML and LaTeX are both enabled. The LaTeX output is intended as the
# foundation for later pretty PDF manuals.

PROJECT_NAME           = "configlib"
PROJECT_BRIEF          = "Policy and fact driven configuration resolution library"
PROJECT_NUMBER         = "0.8.1"
OUTPUT_DIRECTORY       = build/docs
INPUT                  = include docs README.md
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp *.h *.md
EXCLUDE_PATTERNS       = */build/*

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
MULTILINE_CPP_IS_BRIEF = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
LATEX_CMD_NAME         = latex
PDF_HYPERLINKS         = YES
USE_PDFLATEX           = YES
COMPACT_LATEX          = NO
LATEX_BATCHMODE        = NO

GENERATE_TREEVIEW      = YES
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .
CASE_SENSE_NAMES       = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = NO
