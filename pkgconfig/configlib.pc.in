prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${exec_prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: configlib
Description: Policy and fact driven configuration resolution library
Version: @PROJECT_VERSION@
Libs: -L${libdir} -lconfiglib
Cflags: -I${includedir}
